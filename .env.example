# ============================================
# convergio-kernel — Environment Variables
# ============================================

# --- Infrastructure ---
# URL of the Convergio daemon (default: http://127.0.0.1:7777)
# CONVERGIO_DAEMON_URL=http://127.0.0.1:7777

# Name of this kernel node
# CONVERGIO_NODE_NAME=my-node

# --- Notifications (Telegram) ---
# Telegram bot token for sending notifications
# CONVERGIO_TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Telegram chat ID for receiving notifications
# CONVERGIO_TELEGRAM_CHAT_ID=your-chat-id-here
